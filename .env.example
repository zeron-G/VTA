# =============================================================================
# Virtual Teaching Assistant (VTA) — environment template.
#
# Copy this file to `.env` and adjust as needed:
#     cp .env.example .env
#
# Conventions:
#   - All variable names are UPPER_SNAKE_CASE. This matters: the
#     EnvSecretsProvider in @vta/shared reads secrets straight from
#     process.env by their UPPER_SNAKE name (no transformation), so any
#     secret you expect EnvSecretsProvider to resolve must be defined here
#     using the exact UPPER_SNAKE key it will request.
#   - Values shown below are local-development defaults aligned with
#     docker-compose.yml. Do NOT commit a real `.env` with live secrets.
# =============================================================================

# ---- Core runtime -----------------------------------------------------------

# Node environment. Use "development" locally; "production" in deployed envs.
NODE_ENV=development

# Selects the active LLM profile (model routing / role mapping). Both "dev" and
# "prod" authenticate every role with API keys: DeepSeek (primary chat) +
# OpenAI (fallback chat + embeddings).
LLM_PROFILE=dev

# ---- Datastores (match docker-compose.yml) ----------------------------------

# PostgreSQL connection string. Matches the postgres service:
#   user=vta password=vta db=vta host=localhost port=5432
# The database has the pgvector extension enabled (see infra/postgres/init.sql).
DATABASE_URL=postgres://vta:vta@localhost:5432/vta

# Redis connection string. Matches the redis service (used by BullMQ).
REDIS_URL=redis://localhost:6379

# ---- Secrets provider -------------------------------------------------------

# Which SecretsProvider implementation @vta/shared should construct:
#   - "env":       EnvSecretsProvider — reads secrets from process.env.
#   - "keyvault":  KeyVaultSecretsProvider — reads from Azure Key Vault.
# Local development uses "env" so secrets come from this file.
SECRETS_PROVIDER=env

# Azure Key Vault URL. Only used when SECRETS_PROVIDER=keyvault.
# Leave blank for local development (env provider).
AZURE_KEY_VAULT_URL=

# ---- Logging ----------------------------------------------------------------

# Pino log level: trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info

# =============================================================================
# LLM credentials (API keys only — Codex/ChatGPT OAuth has been removed)
# -----------------------------------------------------------------------------
# Every LLM role authenticates with an API key, resolved from this file (via
# EnvSecretsProvider) in dev, or from Key Vault in production:
#   - DeepSeek = primary chat model     (secret `deepseek.api-key` -> DEEPSEEK_API_KEY)
#   - OpenAI   = fallback chat + embeddings (secret `openai.api-key` -> OPENAI_API_KEY)
# You need BOTH keys to exercise the full pipeline (agent + RAG embeddings).
# =============================================================================

# DeepSeek API key — primary chat model.
DEEPSEEK_API_KEY=

# OpenAI API key — fallback chat model + embeddings.
OPENAI_API_KEY=

# DeepSeek API base URL (override if using a non-default or proxied endpoint),
# e.g. https://api.deepseek.com
DEEPSEEK_BASE_URL=

# -----------------------------------------------------------------------------
# Per-course channel tokens (Phase 1):
#
# Per-course secrets follow the EnvSecretsProvider UPPER_SNAKE naming
# convention. Course-scoped tokens are suffixed with the upper-cased course
# identifier so each course can carry its own credentials, e.g. for a course
# whose id resolves to "CS101":
#
#   CANVAS_TOKEN_CS101=...        # Canvas LMS API token for course CS101
#
# Discord uses a single bot token for the application (the bot is invited to
# each course's guild/channel; per-course routing happens in app config rather
# than via per-course tokens):
#
#   DISCORD_BOT_TOKEN=...         # Discord bot token for the VTA application
#
# These are intentionally left undefined here — add the specific keys you need
# once Phase-1 channels are implemented.
# -----------------------------------------------------------------------------
