# Copy to .env and replace every REPLACE_ME value. Never commit .env.
COURSE_TA_PROFILE=course-ta
COURSE_TA_STATE_DIR=
COURSE_TA_WORKSPACE_DIR=
# Leave empty to use the course-ta skill bundled in the VTA package.
COURSE_TA_SKILL_SOURCE=
COURSE_TA_OPENCLAW_VERSION=2026.6.8
COURSE_TA_GATEWAY_PORT=18790
COURSE_TA_GATEWAY_TOKEN=

# codex-oauth launches an interactive browser/device login when needed.
# Other modes: openai-api-key, existing
COURSE_TA_MODEL_AUTH=codex-oauth
COURSE_TA_MODEL=openai/gpt-5.5
OPENAI_API_KEY=
CODEX_HOME=~/.codex

COURSE_TA_CANVAS_BASE_URL=https://REPLACE_ME.instructure.com
COURSE_TA_CANVAS_ACCESS_TOKEN=REPLACE_ME
COURSE_TA_CANVAS_COURSE_ID=123456
COURSE_TA_CANVAS_SYNC_INTERVAL_HOURS=6

COURSE_TA_DISCORD_BOT_TOKEN=REPLACE_ME
COURSE_TA_DISCORD_GUILD_ID=123456789012345678
# IDs and https://discord.com/channels/<guild>/<channel> URLs can be mixed.
COURSE_TA_DISCORD_CHANNELS=123456789012345679
COURSE_TA_DISCORD_BLOCKED_CHANNELS=
COURSE_TA_REQUIRE_MENTION=true
COURSE_TA_ADMIN_USERS=123456789012345680
COURSE_TA_PRIVILEGED_USERS_JSON={}

COURSE_TA_COURSE_SLUG=replace-me-course
COURSE_TA_COURSE_NAME=Replace Me Course
COURSE_TA_COURSE_SECTION=01
COURSE_TA_COURSE_CODE=
COURSE_TA_PROFESSOR_NAME=
COURSE_TA_SEMESTER=
COURSE_TA_MATERIALS_DIR=

COURSE_TA_INSTALL_PYTHON_DEPS=true
COURSE_TA_INITIAL_CANVAS_SYNC=true
COURSE_TA_INSTALL_GATEWAY=true
